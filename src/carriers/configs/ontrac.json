{
  "id": "ontrac",
  "displayName": "OnTrac",
  "mode": "scraper",
  "warmUrl": "https://www.ontrac.com/tracking/?number={n}",
  "awaitReady": "body",
  "queryStrategy": "in_page_fetch",
  "fetchUrl": "https://www.ontrac.com/tracking/?number={n}",
  "parseHtml": { "events": ".tracking-event, .event, li", "date": "time, .date", "location": ".location", "description": ".status, .description" },
  "statusMap": [
    { "status": "delivered", "pattern": "delivered" },
    { "status": "exception", "pattern": "exception|delay|unable|returned" },
    { "status": "pickup", "pattern": "pickup|accepted" },
    { "status": "in_transit", "pattern": "transit|facility|arrived|departed|out for delivery" }
  ],
  "trackingNumberPattern": "^[CD]\\d{14}$|^1LS[A-Z0-9]{12,20}$",
  "regions": ["US"],
  "tier": 1
}
