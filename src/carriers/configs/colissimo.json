{
  "id": "colissimo",
  "displayName": "Colissimo",
  "mode": "scraper",
  "warmUrl": "https://www.laposte.fr/outils/suivre-vos-envois?code={n}",
  "awaitReady": "body",
  "queryStrategy": "in_page_fetch",
  "fetchUrl": "https://www.laposte.fr/outils/suivre-vos-envois?code={n}",
  "parseHtml": {
    "events": ".tracking-event, .shipment-event, .event, .timeline-item, [data-testid*='event'], [class*='event'], [class*='timeline'] li",
    "date": "time, .date, .event-date, [class*='date']",
    "location": ".location, .event-location, [class*='location'], [class*='place']",
    "description": ".status, .description, .event-description, [data-testid*='status'], [class*='status'], [class*='description'], h3, h4"
  },
  "failurePatterns": [
    "access denied",
    "aucun envoi",
    "aucune information",
    "not found",
    "no shipment"
  ],
  "statusMap": [
    { "status": "delivered", "pattern": "delivered|livr|signed|remis" },
    { "status": "exception", "pattern": "exception|incident|failed|returned|retour|unable|delay|customs|held" },
    { "status": "pickup", "pattern": "accepted|received|collected|pickup|pris en charge|depose" },
    { "status": "in_transit", "pattern": "in transit|transit|arrived|departed|out for delivery|achemin|tri|livraison" }
  ],
  "trackingNumberPattern": "^[A-Z]{2}\\d{9}FR$|^\\d[A-Z]\\d{11}$|^[A-Z0-9]{11,18}$",
  "regions": ["FR"],
  "tier": 1
}
