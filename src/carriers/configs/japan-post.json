{
  "id": "japan-post",
  "displayName": "Japan Post",
  "mode": "scraper",
  "warmUrl": "https://trackings.post.japanpost.jp/services/srv/search/direct?reqCodeNo1={n}&locale=en",
  "awaitReady": "body",
  "queryStrategy": "in_page_fetch",
  "fetchUrl": "https://trackings.post.japanpost.jp/services/srv/search/direct?reqCodeNo1={n}&locale=en",
  "parseHtml": { "events": "tr, .tracking-event, .event", "date": "td:nth-child(1), time, .date", "location": "td:nth-child(4), .location", "description": "td:nth-child(2), .status, .description" },
  "statusMap": [
    { "status": "delivered", "pattern": "delivered|final delivery" },
    { "status": "exception", "pattern": "retention|returned|failed|exception" },
    { "status": "pickup", "pattern": "available|pickup" },
    { "status": "in_transit", "pattern": "arrival|dispatch|posting|processing|in transit" }
  ],
  "trackingNumberPattern": "^[A-Z]{2}\\d{9}JP$|^\\d{11,13}$",
  "regions": ["JP"],
  "tier": 1
}
