{
  "id": "speedeedelivery",
  "displayName": "Spee-Dee Delivery",
  "mode": "scraper",
  "warmUrl": "https://packages.speedeedelivery.com/package_progress.php?v=detail&barcode={n}",
  "awaitReady": "tbody tr",
  "queryStrategy": "in_page_fetch",
  "fetchUrl": "https://packages.speedeedelivery.com/package_progress.php?v=detail&barcode={n}",
  "parseHtml": { "events": "tbody tr", "date": "td:nth-child(1)", "location": "td:nth-child(2)", "description": "td:nth-child(3)" },
  "statusMap": [
    { "status": "delivered", "pattern": "delivered" },
    { "status": "exception", "pattern": "exception|delay|unable|returned" },
    { "status": "pickup", "pattern": "pickup|accepted" },
    { "status": "in_transit", "pattern": "transit|facility|arriv|arrival scan|departed|out for delivery" }
  ],
  "trackingNumberPattern": "^\\d{10,22}$",
  "regions": ["US"],
  "tier": 1
}
