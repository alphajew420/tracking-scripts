{
  "name": "tracking-scripts",
  "version": "0.1.0",
  "description": "Carrier tracking library + API skeleton built around browser-driven scrapers for UPS, FedEx, DHL, DHL Express, USPS, and config-driven carriers.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "api": "tsx src/server.ts",
    "worker": "tsx src/workers/scrape-worker.ts",
    "webhook-worker": "tsx src/workers/webhook-worker.ts",
    "scheduler": "tsx src/workers/scheduler.ts",
    "migrate": "tsx src/db.ts",
    "carriers:catalog": "node scripts/fetch-carrier-catalogs.mjs",
    "carriers:backlog": "node scripts/build-carrier-implementation-backlog.mjs",
    "carriers:backlog:all": "node scripts/build-carrier-backlog.mjs",
    "carriers:status": "tsx src/tools/carrier-status.ts",
    "carriers:validate": "tsx src/tools/validate-carriers.ts",
    "carriers:api-validate": "tsx src/tools/validate-carrier-api-registry.ts",
    "carriers:api-check": "tsx src/tools/validate-carrier-api-adapters.ts",
    "carriers:verify": "tsx src/tools/verify-carrier-samples.ts",
    "typecheck": "tsc --noEmit",
    "proxy:diagnose": "tsx src/tools/proxy-diagnostics.ts",
    "browser:surface": "tsx src/tools/browser-surface.ts",
    "cdp:chrome": "tsx src/tools/launch-cdp-chrome.ts",
    "proxy:ip-stability": "tsx src/tools/proxy-ip-stability.ts",
    "probe:bandwidth-fedex": "tsx probes/bandwidth_fedex_warm.ts",
    "probe:bandwidth-usps": "tsx probes/bandwidth_usps_warm.ts",
    "probe:bandwidth-usps-cold": "tsx probes/bandwidth_usps.ts",
    "postinstall": "patchright install chromium"
  },
  "dependencies": {
    "bullmq": "^5.78.0",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "patchright": "^1.49.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "shipping",
    "tracking",
    "ups",
    "fedex",
    "dhl",
    "usps",
    "playwright",
    "scraper"
  ],
  "license": "MIT"
}
