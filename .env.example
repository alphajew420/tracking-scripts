# Core
NODE_ENV=production
APP_BASE_URL=https://trackified.dev
API_PUBLIC_BASE_URL=https://api.trackified.dev
DATABASE_URL=postgres://trackified:trackified@postgres:5432/trackified
REDIS_URL=redis://redis:6379

# Security
TRACKING_API_KEYS=
CORS_ORIGIN=https://trackified.dev
COOKIE_SECURE=true

# Dashboard web
NEXT_PUBLIC_API_BASE_URL=https://api.trackified.dev
API_INTERNAL_BASE_URL=http://api:8787

# Email
EMAIL_PROVIDER=dev
EMAIL_FROM=Trackified <no-reply@trackified.dev>
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_SUCCESS_URL=https://trackified.dev/dashboard/billing?checkout=success
STRIPE_CANCEL_URL=https://trackified.dev/dashboard/billing?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=https://trackified.dev/dashboard/billing

# Plan defaults
FREE_TRACKINGS_LIMIT=100
FREE_RATE_LIMIT_PER_MINUTE=60
DEFAULT_BULK_LIMIT=5
DEFAULT_OVERAGE_USD_PER_TRACKING=0.01

# Workers
WORKER_CONCURRENCY=2
WEBHOOK_WORKER_CONCURRENCY=10
SCHEDULER_INTERVAL_MS=60000
SCHEDULER_BATCH_SIZE=100
SCHEDULER_WEBHOOK_BATCH_SIZE=100
HEADLESS=false
HEADLESS_FEDEX=false
SESSION_MAX_AGE_MS=3600000
SESSION_MAX_USES=250
BROWSER_CHANNEL_FEDEX=chrome
BROWSER_USER_AGENT_FEDEX=native
BROWSER_CDP_AUTOLAUNCH_FEDEX=false
BROWSER_CDP_ENDPOINT=
BROWSER_CDP_ENDPOINT_ROYAL_MAIL=
BROWSER_CDP_ENDPOINT_POSTNORD_SE=
BROWSER_CDP_ENDPOINT_POSTNORD_DK=
BROWSER_EXTRA_ARGS=
BROWSER_EXTRA_ARGS_ROYAL_MAIL=

# Optional sticky proxies
PROXY_MODE=
PROXY_DEFAULT=
PROXY_DEFAULT_USERNAME=
PROXY_DEFAULT_PASSWORD=
PROXY_COUNTRY=us
PROXY_SESSION=
PROXY_SESSION_FEDEX=
PROXY_SESSION_FALLBACKS_FEDEX=
PROXY_USPS=
PROXY_USPS_USERNAME=
PROXY_USPS_USERNAME_TEMPLATE=
PROXY_USPS_PASSWORD=
PROXY_UPS=
PROXY_UPS_USERNAME=
PROXY_UPS_USERNAME_TEMPLATE=
PROXY_UPS_PASSWORD=
PROXY_FEDEX=
PROXY_FEDEX_USERNAME=
# Prefer carrier-scoped templates for FedEx so sticky/session policy can differ from other carriers.
# Example: user-country-US-session-{session}-refreshMinutes-10
PROXY_FEDEX_USERNAME_TEMPLATE=
PROXY_FEDEX_PASSWORD=
PROXY_FEDEX_MODE=native
PROXY_SESSION_PREFIX_FEDEX=fedexprod
PROXY_SESSION_BAD_TTL_SECONDS_FEDEX=1800
PROXY_PICK_ATTEMPTS_FEDEX=4
FEDEX_DISABLE_BLOCKING=false
FEDEX_FINGERPRINT_PROFILE=none
FEDEX_TRACK_SURFACE=landing
BROWSER_EXTRA_ARGS_FEDEX=--no-sandbox --disable-dev-shm-usage
FEDEX_PROFILE_DIR=/tmp/trackified-fedex-profile-worker
FEDEX_PROFILE_ISOLATION=ephemeral
FEDEX_ALLOW_DYNAMIC_PROXY_SESSIONS=false
FEDEX_CANARY_TRACKING_NUMBER=382150811542
FEDEX_CANARY_TIMEOUT_MS=240000
CANARY_INTERVAL_MS_FEDEX=900000
SCRAPE_TIMEOUT_MS_FEDEX=240000
FEDEX_WARM_TIMEOUT_MS=180000
FEDEX_READY_TIMEOUT_MS=45000
ROYAL_MAIL_DISABLE_BLOCKING=true
ROYAL_MAIL_PROFILE_DIR=/tmp/trackified-royal-mail-profile
ROYAL_MAIL_WARM_TIMEOUT_MS=90000
ROYAL_MAIL_READY_TIMEOUT_MS=25000
POSTNORD_DISABLE_BLOCKING=true
POSTNORD_PROFILE_DIR=/tmp/trackified-postnord-profile
POSTNORD_WARM_TIMEOUT_MS=90000
POSTNORD_READY_TIMEOUT_MS=25000
